digraph "Optimization::IPMQPSolver&lt; N_vars, N_eq, N_ineq &gt;"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [id="Node000001",label="Optimization::IPMQPSolver\l\< N_vars, N_eq, N_ineq \>",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip="Layer 4 - Primal-Dual Interior-Point Method (IPM) QP Solver."];
  Node2 -> Node1 [id="edge1_Node000001_Node000002",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" P",fontcolor="grey" ];
  Node2 [id="Node000002",label="StaticMatrix\< double,\l N_vars, N_vars \>",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$classStaticMatrix.html",tooltip=" "];
  Node3 -> Node1 [id="edge2_Node000001_Node000003",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" q",fontcolor="grey" ];
  Node3 [id="Node000003",label="StaticMatrix\< double,\l N_vars \>",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$classStaticMatrix.html",tooltip=" "];
  Node4 -> Node1 [id="edge3_Node000001_Node000004",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" A_eq\nb_eq",fontcolor="grey" ];
  Node4 [id="Node000004",label="N_eq",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
  Node5 -> Node1 [id="edge4_Node000001_Node000005",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" A_ineq\nb_ineq",fontcolor="grey" ];
  Node5 [id="Node000005",label="N_ineq",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
}
